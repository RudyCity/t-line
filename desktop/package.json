{
  "name": "desktop",
  "version": "1.3.45",
  "description": "Electron desktop wrapper for t-line",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "30.0.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.tline.manager",
    "publish": null,
    "productName": "t-line",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "icon.png",
      "../backend/dist/**/*",
      "../backend/node_modules/**/*",
      "../backend/package.json",
      "../frontend/dist/**/*"
    ],
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "asar": true
  }
}
