{
  "name": "desktop",
  "version": "1.3.227",

  "description": "Electron desktop wrapper for t-line",
  "author": {
    "name": "Rudy H.",
    "email": "hrudy715@gmail.com"
  },
  "homepage": "https://github.com/RudyCity/t-line",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "node copy-assets.js && electron-builder --dir",
    "dist": "node copy-assets.js && electron-builder"
  },
  "devDependencies": {
    "electron": "30.0.6",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.1.0-beta21",
    "ws": "^8.17.0"
  },
  "build": {
    "appId": "com.tline.manager",
    "publish": {
      "provider": "github",
      "owner": "RudyCity",
      "repo": "t-line"
    },
    "productName": "t-line",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "updater.js",
      "connection-error.html",
      "package.json",
      "icon.png",
      "backend/dist/**/*",
      "backend/package.json",
      "frontend/dist/**/*"
    ],
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Rudy H. <hrudy715@gmail.com>"
    },
    "asar": true
  }
}

